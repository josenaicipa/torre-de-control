# Torre de Control v2 — environment template.
# Copy to .env and fill in real values locally. NEVER commit a real .env.
# All values below are placeholders only.

# --- Database ---
# Local dev (docker-compose postgres on host port 5438):
DATABASE_URL="postgresql://torre:torre@localhost:5438/torre_control"
# Production target is AWS RDS PostgreSQL (set in the deploy environment, not here).

# --- Auth ---
# Secret used to sign HttpOnly session cookies (HMAC-SHA256).
# Generate a strong random value, e.g.: openssl rand -base64 48
AUTH_SECRET="replace-with-a-long-random-string"

# --- Admin bootstrap (optional) ---
# Optional shared token reserved for a future bootstrap flow. Leave unset if unused.
ADMIN_BOOTSTRAP_TOKEN=""

# Used ONLY by `npm run user:create-admin` to avoid passing passwords on the CLI.
# Set it inline for a single command instead of committing it:
#   TORRE_ADMIN_PASSWORD='...' npm run user:create-admin -- --email you@example.com
TORRE_ADMIN_PASSWORD=""
