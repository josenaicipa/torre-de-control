// Torre de Control v2 data model.
// Provider: PostgreSQL (local via docker-compose; production target AWS RDS).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
  MENTOR
}

// Panel-controlled operational cargo. Drives what each user is allowed to see.
// Naming is fixed: Closer, Setter, Director, Admin, Viewer (never Comercial/Jefe).
enum OperationalPosition {
  ADMIN
  DIRECTOR
  CLOSER
  SETTER
  VIEWER
}

// How wide a user's data window is. The data-scope helper turns this into a
// concrete backend filter descriptor.
enum DataScope {
  ALL // every record
  AREA // limited to the user's area
  TEAM // limited to the user's team
  OWN // only the user's own GHL-attributed records
  CUSTOM // bespoke rules (not yet configured -> denied by the helper)
}

// A top-level business area (e.g. Ventas, Marketing). Groups teams and users.
model Area {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams Team[]
  users User[]
}

// A team inside an area (e.g. a closing squad). Optional area link.
model Team {
  id        String   @id @default(cuid())
  name      String
  areaId    String?
  area      Area?    @relation(fields: [areaId], references: [id], onDelete: SetNull)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@unique([areaId, name])
  @@index([areaId])
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String
  role         Role         @default(VIEWER)
  permissions  String[]     @default([])
  active       Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Scoped-dashboard configuration (panel-controlled, tied to GHL).
  position  OperationalPosition @default(VIEWER)
  dataScope DataScope           @default(ALL)

  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id], onDelete: SetNull)
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Director / responsable above this user.
  managerId String?
  manager   User?   @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports   User[]  @relation("UserManager")

  // GHL identity used to attribute records to this user under OWN scope.
  ghlUserId    String?
  ghlUserEmail String?
  ghlUserName  String?

  isCollector  Boolean      @default(false)

  auditEvents     AuditEvent[]
  commercialNotes CommercialNote[]
  mentor               Mentor?
  recordedPayments     Payment[]                @relation("PaymentRecorder")
  submittedProgress    ProgressUpdate[]         @relation("ProgressSubmitter")
  reportedMetrics      StudentMonthlyMetrics[]  @relation("MetricsReporter")
  resolvedTerminations TerminationAlert[]       @relation("TerminationResolver")
  uploadedImports      ImportBatch[]            @relation("ImportUploader")

  @@index([role])
  @@index([position])
  @@index([dataScope])
  @@index([areaId])
  @@index([teamId])
  @@index([managerId])
  @@index([ghlUserId])
}

// Append-only trail of who did what.
model AuditEvent {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

// Lineage / dedupe record for each external import (CRM, ad spend, etc.).
model SourceSnapshot {
  id         String   @id @default(cuid())
  source     String
  sourceDate DateTime
  hash       String
  rawSummary Json?
  createdAt  DateTime @default(now())

  @@unique([source, hash])
  @@index([source, sourceDate])
}

// One row per (date, channel) of normalized daily KPIs.
model DailyMetric {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  channel   String
  spend     Decimal  @default(0) @db.Decimal(14, 2)
  booked    Int      @default(0)
  showed    Int      @default(0)
  closed    Int      @default(0)
  revenue   Decimal  @default(0) @db.Decimal(14, 2)
  raw       Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, channel])
  @@index([date])
}

// Manual commercial annotations on a lead/contact, with GHL sync status.
model CommercialNote {
  id          String   @id @default(cuid())
  contactId   String?
  email       String?
  outcome     String?
  note        String
  ghlSyncStatus String @default("pending")
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
  @@index([email])
  @@index([ownerId])
}

// ─── Dashboard data tables ───────────────────────────────────────────────────
// These four tables back public/index.html through /api/dashboard/{select,mutate,
// import}. They migrated off Supabase to RDS so the server-side dashboard works
// inside App Runner's VPC. Column names are snake_case to match the browser's
// existing payloads exactly; the writable column whitelist and scope rules live
// in src/lib/dashboard-tables.ts (the access source of truth). The store
// (src/lib/dashboard-store.ts) reads/writes these via parameterized raw SQL, not
// the Prisma client, but the models are kept here so the schema and migrations
// stay drift-free.

// Company-wide monthly KPI funnel + targets. One row per (year, month).
// `month` is 0-indexed to match the browser (0 = January).
model KpiData {
  year                    Int
  month                   Int
  revenue                 Decimal? @db.Decimal(18, 2)
  ad_spend                Decimal? @db.Decimal(18, 2)
  leads                   Int?
  agendas                 Int?
  shows                   Int?
  cierres                 Int?
  meta_revenue            Decimal? @db.Decimal(18, 2)
  day                     Int?
  pct_leads_agendadas     Decimal? @db.Decimal(8, 2)
  pct_agendadas_asistidas Decimal? @db.Decimal(8, 2)
  close_rate_meta         Decimal? @db.Decimal(8, 2)
  inversion_planeada      Decimal? @db.Decimal(18, 2)
  roas_objetivo           Decimal? @db.Decimal(8, 2)

  @@id([year, month])
  @@map("kpi_data")
}

// Per-collaborator daily marketing + organic-closer figures. One row per
// (date, member). `member` is the only row-level scope key in the dashboard.
model DailyEntry {
  date             DateTime @db.Date
  member           String
  ig_followers     Int?
  posts            Int?
  mensajes         Int?
  follow_ups       Int?
  bk_offers        Int?
  gasto_meta       Decimal? @db.Decimal(18, 2)
  gasto_google     Decimal? @db.Decimal(18, 2)
  gasto_tiktok     Decimal? @db.Decimal(18, 2)
  gasto_otros      Decimal? @db.Decimal(18, 2)
  new_bk_organic   Int?
  qual_bk_organic  Int?
  today_bk_organic Int?
  show_organic     Int?
  sales_organic    Int?
  revenue_organic  Decimal? @db.Decimal(18, 2)
  cash_organic     Decimal? @db.Decimal(18, 2)
  recurring_organic Decimal? @db.Decimal(18, 2)
  pitches_organic  Int?
  pitches_paid     Int?
  reservas_organic Int?

  @@id([date, member])
  @@map("daily_entries")
}

// Individual ad-spend line items, grouped in the UI by (year, month). Carries a
// surrogate id because rows are added/removed individually from the browser.
model AdsEntry {
  id          Int      @id @default(autoincrement())
  year        Int?
  month       Int?
  fecha       DateTime? @db.Date
  canal       String?
  gasto       Decimal? @db.Decimal(18, 2)
  impresiones Int?
  clicks      Int?
  revenue     Decimal? @db.Decimal(18, 2)

  @@index([year, month])
  @@index([fecha])
  @@map("ads_entries")
}

// Company-wide daily closer ledger. One row per date.
model DailyCloser {
  date                   DateTime @id @db.Date
  q_ventas_ht            Int?
  valor_venta_ht         Decimal? @db.Decimal(18, 2)
  upfront_cash_ht        Decimal? @db.Decimal(18, 2)
  ventas_cash            Decimal? @db.Decimal(18, 2)
  recurring_cash         Decimal? @db.Decimal(18, 2)
  q_ventas_lt            Int?
  valor_venta_lt         Decimal? @db.Decimal(18, 2)
  total_clientes_activos Int?
  q_reservas             Int?
  cash_reservas          Decimal? @db.Decimal(18, 2)
  q_reembolsos           Int?
  valor_reembolsos       Decimal? @db.Decimal(18, 2)
  agendas_organicas      Int?
  agendas_meta           Int?
  agendas_google         Int?
  agendas_tiktok         Int?
  agendas_otros          Int?
  cal_organicas          Int?
  cal_meta               Int?
  cal_google             Int?
  cal_tiktok             Int?
  cal_otros              Int?
  hoy_organicas          Int?
  hoy_meta               Int?
  hoy_google             Int?
  hoy_tiktok             Int?
  hoy_otros              Int?
  show_organicas         Int?
  show_meta              Int?
  show_google            Int?
  show_tiktok            Int?
  show_otros             Int?
  agendas_calificadas    Int?
  agendas_final          Int?
  citas_asistidas        Int?

  @@map("daily_closer")
}

// ─── Operaciones module ──────────────────────────────────────────────────────

enum StudentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  DROPPED
  EXTENDED
  ACCESS_REVOKED
}

enum ScheduleStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  WAIVED
}

enum ImportStatus {
  PENDING
  PREVIEW_READY
  CONFIRMING
  COMPLETED
  ERRORED
}

enum ProgressLevel {
  ALTO
  MEDIO
  BAJO
  SIN_DATO
}

model Mentor {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students        Student[]
  progressUpdates ProgressUpdate[]

  @@index([active])
}

model Program {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  name                  String
  durationMonthsDefault Int      @default(12)
  description           String?
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  students Student[]
}

model Student {
  id                   String         @id @default(cuid())
  fullName             String
  email                String         @unique
  phone                String?
  startDate            DateTime       @db.Date
  durationMonths       Int
  endDate              DateTime       @db.Date
  mentorId             String?
  mentor               Mentor?        @relation(fields: [mentorId], references: [id], onDelete: SetNull)
  programId            String?
  program              Program?       @relation(fields: [programId], references: [id], onDelete: SetNull)
  status               StudentStatus  @default(ACTIVE)
  durationAssumed      Boolean        @default(false)
  closedAt             DateTime?      @db.Date
  legacyRowId          Int?
  ghlContactId         String?
  notes                String?
  currentProgressLevel ProgressLevel  @default(SIN_DATO)
  currentBottleneck    String?
  personality          String?
  legalName            String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  members             StudentMember[]
  attributions        SaleAttribution[]
  paymentSchedules    PaymentSchedule[]
  payments            Payment[]
  progressUpdates     ProgressUpdate[]
  monthlyMetrics      StudentMonthlyMetrics[]
  sales               Sale[]
  terminations        TerminationAlert[]
  promotedFromContact Contact?                @relation("ContactPromotion")

  @@index([mentorId])
  @@index([programId])
  @@index([status])
  @@index([legacyRowId])
}

model StudentMember {
  id               String   @id @default(cuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fullName         String
  email            String?
  phone            String?
  isPrimaryContact Boolean  @default(false)
  ghlContactId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([studentId, email])
  @@index([studentId])
}

model SaleAttribution {
  id               String   @id @default(cuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  collaboratorName String
  role             String?
  createdAt        DateTime @default(now())

  @@unique([studentId, collaboratorName])
  @@index([studentId])
}

model PaymentSchedule {
  id                String         @id @default(cuid())
  studentId         String
  student           Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  installmentNumber Int
  amountDue         Decimal        @db.Decimal(14, 2)
  currency          String         @default("USD")
  dueDate           DateTime       @db.Date
  status            ScheduleStatus @default(PENDING)
  amountPaid        Decimal        @default(0) @db.Decimal(14, 2)
  paidAt            DateTime?
  lastReminderAt    DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  payments     Payment[]
  reminderLogs ReminderLog[]

  @@index([studentId])
  @@index([dueDate])
  @@index([status])
}

model Payment {
  id           String           @id @default(cuid())
  studentId    String
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scheduleId   String?
  schedule     PaymentSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  amount       Decimal          @db.Decimal(14, 2)
  currency     String           @default("USD")
  paidAt       DateTime
  method       String?
  reference    String?
  notes        String?
  recordedById String?
  recordedBy   User?            @relation("PaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())

  @@index([studentId])
  @@index([paidAt])
}

model ProgressUpdate {
  id                     String        @id @default(cuid())
  studentId              String
  student                Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentorId               String
  mentor                 Mentor        @relation(fields: [mentorId], references: [id])
  periodStart            DateTime      @db.Date
  periodEnd              DateTime      @db.Date
  notes                  String
  rating                 Int?
  progressLevel          ProgressLevel
  bottleneck             String?
  monthlyRevenue         Decimal?      @db.Decimal(14, 2)
  monthlyRevenueCurrency String?
  monthlyOrders          Int?
  submittedAt            DateTime      @default(now())
  submittedById          String?
  submittedBy            User?         @relation("ProgressSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)

  @@index([studentId, periodEnd])
  @@index([mentorId])
}

model StudentMonthlyMetrics {
  id           String    @id @default(cuid())
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  year         Int
  month        Int
  revenue      Decimal   @default(0) @db.Decimal(14, 2)
  currency     String    @default("COP")
  orders       Int       @default(0)
  status       String?
  notes        String?
  reportedAt   DateTime?
  reportedById String?
  reportedBy   User?     @relation("MetricsReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([studentId, year, month, currency])
  @@index([year, month])
}

model Contact {
  id                  String   @id @default(cuid())
  fullName            String
  email               String?  @unique
  phone               String?
  source              String
  notes               String?
  promotedToStudentId String?  @unique
  promotedToStudent   Student? @relation("ContactPromotion", fields: [promotedToStudentId], references: [id], onDelete: SetNull)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sales Sale[]
}

model Sale {
  id            String       @id @default(cuid())
  studentId     String?
  student       Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  amount        Decimal      @db.Decimal(14, 2)
  currency      String       @default("USD")
  saleDate      DateTime     @db.Date
  product       String?
  source        String
  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  rawRow        Json?
  createdAt     DateTime     @default(now())

  @@index([studentId])
  @@index([saleDate])
  @@index([importBatchId])
}

model ImportBatch {
  id              String       @id @default(cuid())
  source          String
  filename        String
  uploadedById    String?
  uploadedBy      User?        @relation("ImportUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  totalRows       Int
  matchedRows     Int          @default(0)
  createdContacts Int          @default(0)
  skippedRows     Int          @default(0)
  status          ImportStatus @default(PENDING)
  errors          Json?
  createdAt       DateTime     @default(now())
  confirmedAt     DateTime?

  sales Sale[]
}

model ReminderLog {
  id                String          @id @default(cuid())
  scheduleId        String
  schedule          PaymentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  channel           String
  recipientType     String
  recipientContact  String
  sentAt            DateTime        @default(now())
  status            String
  errorMessage      String?
  providerMessageId String?

  @@index([scheduleId])
  @@index([sentAt])
}

model TerminationAlert {
  id              String    @id @default(cuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  detectedAt      DateTime  @default(now())
  reason          String
  resolvedById    String?
  resolvedBy      User?     @relation("TerminationResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolution      String?
  resolvedAt      DateTime?
  resolutionNotes String?

  @@index([studentId])
  @@index([resolvedAt])
}

