// Torre de Control v2 data model.
// Provider: PostgreSQL (local via docker-compose; production target AWS RDS).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
  MENTOR
}

// Panel-controlled operational cargo. Drives what each user is allowed to see.
// Naming is fixed: Closer, Setter, Director, Admin, Viewer (never Comercial/Jefe).
enum OperationalPosition {
  ADMIN
  DIRECTOR
  CLOSER
  SETTER
  VIEWER
}

// How wide a user's data window is. The data-scope helper turns this into a
// concrete backend filter descriptor.
enum DataScope {
  ALL // every record
  AREA // limited to the user's area
  TEAM // limited to the user's team
  OWN // only the user's own GHL-attributed records
  CUSTOM // bespoke rules (not yet configured -> denied by the helper)
}

// A top-level business area (e.g. Ventas, Marketing). Groups teams and users.
model Area {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams Team[]
  users User[]
}

// A team inside an area (e.g. a closing squad). Optional area link.
model Team {
  id        String   @id @default(cuid())
  name      String
  areaId    String?
  area      Area?    @relation(fields: [areaId], references: [id], onDelete: SetNull)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@unique([areaId, name])
  @@index([areaId])
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String
  role         Role         @default(VIEWER)
  permissions  String[]     @default([])
  active       Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Scoped-dashboard configuration (panel-controlled, tied to GHL).
  position  OperationalPosition @default(VIEWER)
  dataScope DataScope           @default(OWN)

  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id], onDelete: SetNull)
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Director / responsable above this user.
  managerId String?
  manager   User?   @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports   User[]  @relation("UserManager")

  // GHL identity used to attribute records to this user under OWN scope.
  ghlUserId    String?
  ghlUserEmail String?
  ghlUserName  String?

  isCollector  Boolean      @default(false)

  auditEvents     AuditEvent[]
  commercialNotes CommercialNote[]
  recordedPayments     Payment[]                @relation("PaymentRecorder")
  submittedProgress    ProgressUpdate[]         @relation("ProgressSubmitter")
  reportedMetrics      StudentMonthlyMetrics[]  @relation("MetricsReporter")
  resolvedTerminations TerminationAlert[]       @relation("TerminationResolver")
  uploadedImports      ImportBatch[]            @relation("ImportUploader")
  studentsAsMentor     Student[]                @relation("StudentMentor")
  progressAsMentor     ProgressUpdate[]         @relation("ProgressMentor")
  studentsAsCloser     Student[]                @relation("StudentCloser")
  paymentAccountsOwned PaymentAccount[]         @relation("PaymentAccountOwner")
  dropiImportsUploaded DropiImportBatch[]       @relation("DropiImportUploader")
  dropiFollowUpsAssigned DropiFollowUp[]        @relation("DropiFollowUpAssignee")
  dropiFollowUpsCreated  DropiFollowUp[]        @relation("DropiFollowUpCreator")
  dropiLinkAuditActions  DropiStudentLinkAudit[] @relation("DropiLinkAuditActor")
  enrollmentsApproved    StudentProductEnrollment[] @relation("EnrollmentApprover")
  enrollmentsCeoSigned   StudentProductEnrollment[] @relation("EnrollmentCeoSigner")
  operacionesSettingsUpdated OperacionesSetting[]    @relation("OperacionesSettingUpdater")

  @@index([role])
  @@index([position])
  @@index([dataScope])
  @@index([areaId])
  @@index([teamId])
  @@index([managerId])
  @@index([ghlUserId])
}

// Append-only trail of who did what.
model AuditEvent {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

// Configuración global de Operaciones, key-value. Hoy guarda la firma manuscrita
// fija de Jose Naicipa (key "jose_signature_image") que se estampa en todos los
// contratos aprobados.
model OperacionesSetting {
  key         String   @id
  value       String   @db.Text
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("OperacionesSettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedById])
}

// Lineage / dedupe record for each external import (CRM, ad spend, etc.).
model SourceSnapshot {
  id         String   @id @default(cuid())
  source     String
  sourceDate DateTime
  hash       String
  rawSummary Json?
  createdAt  DateTime @default(now())

  @@unique([source, hash])
  @@index([source, sourceDate])
}

// One row per (date, channel) of normalized daily KPIs.
model DailyMetric {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  channel   String
  spend     Decimal  @default(0) @db.Decimal(14, 2)
  booked    Int      @default(0)
  showed    Int      @default(0)
  closed    Int      @default(0)
  revenue   Decimal  @default(0) @db.Decimal(14, 2)
  raw       Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, channel])
  @@index([date])
}

// Manual commercial annotations on a lead/contact, with GHL sync status.
model CommercialNote {
  id          String   @id @default(cuid())
  contactId   String?
  email       String?
  outcome     String?
  note        String
  ghlSyncStatus String @default("pending")
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
  @@index([email])
  @@index([ownerId])
}

// ─── Dashboard data tables ───────────────────────────────────────────────────
// These four tables back public/index.html through /api/dashboard/{select,mutate,
// import}. They migrated off Supabase to RDS so the server-side dashboard works
// inside App Runner's VPC. Column names are snake_case to match the browser's
// existing payloads exactly; the writable column whitelist and scope rules live
// in src/lib/dashboard-tables.ts (the access source of truth). The store
// (src/lib/dashboard-store.ts) reads/writes these via parameterized raw SQL, not
// the Prisma client, but the models are kept here so the schema and migrations
// stay drift-free.

// Company-wide monthly KPI funnel + targets. One row per (year, month).
// `month` is 0-indexed to match the browser (0 = January).
model KpiData {
  year                    Int
  month                   Int
  revenue                 Decimal? @db.Decimal(18, 2)
  ad_spend                Decimal? @db.Decimal(18, 2)
  leads                   Int?
  agendas                 Int?
  shows                   Int?
  cierres                 Int?
  meta_revenue            Decimal? @db.Decimal(18, 2)
  day                     Int?
  pct_leads_agendadas     Decimal? @db.Decimal(8, 2)
  pct_agendadas_asistidas Decimal? @db.Decimal(8, 2)
  close_rate_meta         Decimal? @db.Decimal(8, 2)
  inversion_planeada      Decimal? @db.Decimal(18, 2)
  roas_objetivo           Decimal? @db.Decimal(8, 2)

  @@id([year, month])
  @@map("kpi_data")
}

// Per-collaborator daily marketing + organic-closer figures. One row per
// (date, member). `member` is the only row-level scope key in the dashboard.
model DailyEntry {
  date             DateTime @db.Date
  member           String
  ig_followers     Int?
  posts            Int?
  mensajes         Int?
  follow_ups       Int?
  bk_offers        Int?
  setter_new_conversations Int?
  setter_new_inbound       Int?
  setter_new_outbound      Int?
  setter_outbound_replies  Int?
  setter_calls_proposed    Int?
  setter_links_sent        Int?
  gasto_meta       Decimal? @db.Decimal(18, 2)
  gasto_google     Decimal? @db.Decimal(18, 2)
  gasto_tiktok     Decimal? @db.Decimal(18, 2)
  gasto_otros      Decimal? @db.Decimal(18, 2)
  new_bk_organic   Int?
  qual_bk_organic  Int?
  today_bk_organic Int?
  show_organic     Int?
  sales_organic    Int?
  revenue_organic  Decimal? @db.Decimal(18, 2)
  cash_organic     Decimal? @db.Decimal(18, 2)
  recurring_organic Decimal? @db.Decimal(18, 2)
  pitches_organic  Int?
  pitches_paid     Int?
  reservas_organic Int?
  showup_notes     String?
  hot_leads_evidence String?
  blockers         String?
  setter_findings  String?

  @@id([date, member])
  @@map("daily_entries")
}

// Individual ad-spend line items, grouped in the UI by (year, month). Carries a
// surrogate id because rows are added/removed individually from the browser.
model AdsEntry {
  id          Int      @id @default(autoincrement())
  year        Int?
  month       Int?
  fecha       DateTime? @db.Date
  canal       String?
  gasto       Decimal? @db.Decimal(18, 2)
  impresiones Int?
  clicks      Int?
  revenue     Decimal? @db.Decimal(18, 2)

  @@index([year, month])
  @@index([fecha])
  @@map("ads_entries")
}

// Company-wide daily closer ledger. One row per date.
model DailyCloser {
  date                   DateTime @id @db.Date
  q_ventas_ht            Int?
  valor_venta_ht         Decimal? @db.Decimal(18, 2)
  upfront_cash_ht        Decimal? @db.Decimal(18, 2)
  ventas_cash            Decimal? @db.Decimal(18, 2)
  recurring_cash         Decimal? @db.Decimal(18, 2)
  q_ventas_lt            Int?
  valor_venta_lt         Decimal? @db.Decimal(18, 2)
  total_clientes_activos Int?
  q_reservas             Int?
  cash_reservas          Decimal? @db.Decimal(18, 2)
  q_reembolsos           Int?
  valor_reembolsos       Decimal? @db.Decimal(18, 2)
  agendas_organicas      Int?
  agendas_meta           Int?
  agendas_google         Int?
  agendas_tiktok         Int?
  agendas_otros          Int?
  cal_organicas          Int?
  cal_meta               Int?
  cal_google             Int?
  cal_tiktok             Int?
  cal_otros              Int?
  hoy_organicas          Int?
  hoy_meta               Int?
  hoy_google             Int?
  hoy_tiktok             Int?
  hoy_otros              Int?
  show_organicas         Int?
  show_meta              Int?
  show_google            Int?
  show_tiktok            Int?
  show_otros             Int?
  agendas_calificadas    Int?
  agendas_final          Int?
  citas_asistidas        Int?

  @@map("daily_closer")
}

// Canonical, append-friendly payment ledger backing the Cash Collected feature.
// One row per real transaction (Hotmart / Stripe / Manual / ...), imported from
// the read-only payments-lead-join truth file and classified by the pure domain
// logic in src/domain/cash-collected.ts. Kept separate from the Operaciones
// `Payment` model on purpose: that model tracks student installment schedules,
// while this is the company-wide cash-truth used by the dashboard.
//
// `externalTransactionId` is the source's own id when present, or a deterministic
// synthetic id otherwise, so (source, externalTransactionId) is a stable upsert
// key and re-imports are idempotent. `classification`, `contributesToCash`,
// `reviewRequired` and `reviewReason` are precomputed at import time.
model DashboardPaymentTransaction {
  id                    String   @id @default(cuid())
  externalTransactionId String?
  source                String
  paidAt                DateTime
  leadName              String?
  leadEmail             String?
  amountUsd             Decimal  @db.Decimal(18, 2)
  amountOriginal        Decimal? @db.Decimal(18, 2)
  currency              String?
  product               String?
  offerName             String?
  paymentType           String?
  buyerType             String?
  classification        String
  contributesToCash     Boolean  @default(true)
  reviewRequired        Boolean  @default(false)
  reviewReason          String?
  raw                   Json?
  importedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([source, externalTransactionId])
  @@index([paidAt])
  @@index([classification])
  @@index([source])
  @@index([reviewRequired])
  @@index([leadEmail])
  @@map("dashboard_payment_transactions")
}

// ─── Operaciones module ──────────────────────────────────────────────────────

enum StudentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  DROPPED
  EXTENDED
  ACCESS_REVOKED
  // Added in PR1 to model the full commercial lifecycle. Existing values are
  // preserved so legacy data keeps mapping; new values capture states the
  // legacy single-program data could not express.
  SEPARATED
  INACTIVE
  WITHDRAWN
}

enum ScheduleStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  WAIVED
}

enum ImportStatus {
  PENDING
  PREVIEW_READY
  CONFIRMING
  COMPLETED
  ERRORED
}

enum ProgressLevel {
  ALTO
  MEDIO
  BAJO
  SIN_DATO
}

model Student {
  id                   String         @id @default(cuid())
  fullName             String
  email                String         @unique
  phone                String?
  startDate            DateTime       @db.Date
  durationMonths       Int
  endDate              DateTime       @db.Date
  mentorUserId         String?
  mentorUser           User?          @relation("StudentMentor", fields: [mentorUserId], references: [id], onDelete: SetNull)
  closerUserId         String?
  closerUser           User?          @relation("StudentCloser", fields: [closerUserId], references: [id], onDelete: SetNull)
  status               StudentStatus  @default(ACTIVE)
  // Lifecycle facets that evolve independently from `status`. Kept as their own
  // enums so commercial reporting (still keyed on `status`) is not coupled to
  // operational state (mentorship paused vs. LearnWorlds access revoked).
  mentorshipStatus     MentorshipStatus @default(IN_PROGRESS)
  accessStatus         AccessStatus     @default(ACTIVE)
  durationAssumed      Boolean        @default(false)
  closedAt             DateTime?      @db.Date
  legacyRowId          Int?
  // Traceability link to the historical cartera import that created this row.
  // Nullable: students created directly in the UI have no import batch.
  importBatchId        String?
  importBatch          ImportBatch?   @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  ghlContactId         String?
  notes                String?
  currentProgressLevel ProgressLevel  @default(SIN_DATO)
  currentBottleneck    String?
  personality          String?
  legalName            String?
  // Datos legales mínimos para emitir el contrato de inscripción real. Todos
  // opcionales para no romper importadores ni datos existentes; el flujo de
  // contrato exige completarlos antes de generar el link de firma.
  documentType         String?
  documentNumber       String?
  legalAddress         String?
  legalCity            String?
  legalState           String?
  legalCountry         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  members             StudentMember[]
  attributions        SaleAttribution[]
  paymentSchedules    PaymentSchedule[]
  payments            Payment[]
  progressUpdates     ProgressUpdate[]
  monthlyMetrics      StudentMonthlyMetrics[]
  sales               Sale[]
  terminations        TerminationAlert[]
  promotedFromContact Contact?                @relation("ContactPromotion")

  enrollments         StudentProductEnrollment[]
  tagAssignments      StudentTagAssignment[]
  referralsMade       Referral[]                 @relation("ReferralReferrer")
  referralsReceived   Referral[]                 @relation("ReferralReferred")

  // Optional back-link from Comunidad Dropi. A student may be linked to one
  // community member when they also report Dropi sales, but the Student model
  // remains the source of truth for mentorship and is never required to have
  // a community-member row.
  dropiCommunityMembers DropiCommunityMember[]
  dropiLinkAuditEntries DropiStudentLinkAudit[] @relation("DropiLinkAuditStudent")

  @@index([mentorUserId])
  @@index([closerUserId])
  @@index([status])
  @@index([mentorshipStatus])
  @@index([accessStatus])
  @@index([legacyRowId])
  @@index([importBatchId])
}

model StudentMember {
  id               String   @id @default(cuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fullName         String
  email            String?
  phone            String?
  isPrimaryContact Boolean  @default(false)
  ghlContactId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([studentId, email])
  @@index([studentId])
}

model SaleAttribution {
  id               String   @id @default(cuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  collaboratorName String
  role             String?
  createdAt        DateTime @default(now())

  @@unique([studentId, collaboratorName])
  @@index([studentId])
}

model PaymentSchedule {
  id                String         @id @default(cuid())
  studentId         String
  student           Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // Optional link to a product enrollment. Legacy schedules predate the
  // products architecture and have no enrollment, so this stays nullable.
  enrollmentId      String?
  enrollment        StudentProductEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  installmentNumber Int
  amountDue         Decimal        @db.Decimal(14, 2)
  currency          String         @default("USD")
  dueDate           DateTime       @db.Date
  status            ScheduleStatus @default(PENDING)
  amountPaid        Decimal        @default(0) @db.Decimal(14, 2)
  paidAt            DateTime?
  lastReminderAt    DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  payments     Payment[]
  reminderLogs ReminderLog[]

  @@index([studentId])
  @@index([enrollmentId])
  @@index([dueDate])
  @@index([status])
}

model Payment {
  id           String           @id @default(cuid())
  studentId    String
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scheduleId   String?
  schedule     PaymentSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  // Optional link to a product enrollment. Legacy payments stay enrollment-less.
  enrollmentId String?
  enrollment   StudentProductEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  amount       Decimal          @db.Decimal(14, 2)
  currency     String           @default("USD")
  // Canonical USD value used for reporting once FX has been resolved.
  officialAmountUsd Decimal?    @db.Decimal(14, 2)
  // What actually arrived in the account (may be in any local currency).
  receivedAmount    Decimal?    @db.Decimal(14, 2)
  receivedCurrency  String?
  exchangeRate      Decimal?    @db.Decimal(18, 8)
  paymentAccountId  String?
  paymentAccount    PaymentAccount? @relation(fields: [paymentAccountId], references: [id], onDelete: SetNull)
  isInitialPayment  Boolean     @default(false)
  initialPaymentType InitialPaymentType?
  paidAt       DateTime
  method       String?
  reference    String?
  notes        String?
  recordedById String?
  recordedBy   User?            @relation("PaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())

  @@index([studentId])
  @@index([enrollmentId])
  @@index([paymentAccountId])
  @@index([paidAt])
}

model ProgressUpdate {
  id                     String        @id @default(cuid())
  studentId              String
  student                Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentorUserId           String
  mentorUser             User          @relation("ProgressMentor", fields: [mentorUserId], references: [id])
  periodStart            DateTime      @db.Date
  periodEnd              DateTime      @db.Date
  notes                  String
  rating                 Int?
  progressLevel          ProgressLevel
  bottleneck             String?
  monthlyRevenue         Decimal?      @db.Decimal(14, 2)
  monthlyRevenueCurrency String?
  monthlyOrders          Int?
  submittedAt            DateTime      @default(now())
  submittedById          String?
  submittedBy            User?         @relation("ProgressSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)

  @@index([studentId, periodEnd])
  @@index([mentorUserId])
}

model StudentMonthlyMetrics {
  id           String    @id @default(cuid())
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  year         Int
  month        Int
  revenue      Decimal   @default(0) @db.Decimal(14, 2)
  currency     String    @default("COP")
  orders       Int       @default(0)
  status       String?
  notes        String?
  reportedAt   DateTime?
  reportedById String?
  reportedBy   User?     @relation("MetricsReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([studentId, year, month, currency])
  @@index([year, month])
}

model Contact {
  id                  String   @id @default(cuid())
  fullName            String
  email               String?  @unique
  phone               String?
  source              String
  notes               String?
  promotedToStudentId String?  @unique
  promotedToStudent   Student? @relation("ContactPromotion", fields: [promotedToStudentId], references: [id], onDelete: SetNull)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sales Sale[]
}

model Sale {
  id            String       @id @default(cuid())
  studentId     String?
  student       Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  amount        Decimal      @db.Decimal(14, 2)
  currency      String       @default("USD")
  saleDate      DateTime     @db.Date
  product       String?
  source        String
  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  rawRow        Json?
  createdAt     DateTime     @default(now())

  @@index([studentId])
  @@index([saleDate])
  @@index([importBatchId])
}

model ImportBatch {
  id              String       @id @default(cuid())
  source          String
  filename        String
  uploadedById    String?
  uploadedBy      User?        @relation("ImportUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  totalRows       Int
  matchedRows     Int          @default(0)
  createdContacts Int          @default(0)
  skippedRows     Int          @default(0)
  status          ImportStatus @default(PENDING)
  errors          Json?
  createdAt       DateTime     @default(now())
  confirmedAt     DateTime?

  sales    Sale[]
  students Student[]
}

model ReminderLog {
  id                String          @id @default(cuid())
  scheduleId        String
  schedule          PaymentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  channel           String
  recipientType     String
  recipientContact  String
  sentAt            DateTime        @default(now())
  status            String
  errorMessage      String?
  providerMessageId String?

  @@index([scheduleId])
  @@index([sentAt])
}

model TerminationAlert {
  id              String    @id @default(cuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  detectedAt      DateTime  @default(now())
  reason          String
  resolvedById    String?
  resolvedBy      User?     @relation("TerminationResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolution      String?
  resolvedAt      DateTime?
  resolutionNotes String?

  @@index([studentId])
  @@index([resolvedAt])
}

// ─── Operaciones · Products architecture (PR1 phase A) ───────────────────────
// Adds the catalog + enrollment spine that future Operaciones work hangs off:
// products, per-student enrollments, payment accounts (FX-aware), tags,
// referrals, and the LearnWorlds access surface. Existing Operaciones tables
// (Student, Payment, PaymentSchedule) link in via *optional* relations so the
// legacy single-program data set keeps working without backfill.

enum ProductSaleLimit {
  // Only one active enrollment per student for this product (e.g. flagship
  // mentorship). Re-selling requires the previous enrollment to be closed.
  ONE_PER_STUDENT
  // No cap (e.g. add-ons, masterclasses, supplemental courses).
  UNLIMITED
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum AccessStatus {
  // No LearnWorlds provisioning has been attempted yet (initial enrollment).
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
  // The last sync to LearnWorlds failed; see `learnWorldsSyncError` on the
  // enrollment for the reason.
  SYNC_ERROR
}

enum MentorshipStatus {
  NOT_STARTED
  IN_PROGRESS
  PAUSED
  FINISHED
}

// Lifecycle of the commercial contract behind an enrollment. Torre de Control
// is the source of truth: a paid enrollment is NOT access. Access to
// LearnWorlds is granted only after the contract is APPROVED from Torre.
// - DRAFT / PENDING_SIGNATURE / SIGNED model the signing pipeline (data may
//   arrive from GHL/n8n in later blocks).
// - PENDING_APPROVAL is the state a new enrollment lands in: it waits for an
//   operator/admin to approve from Torre.
// - APPROVED is the only state that triggers LearnWorlds provisioning.
// - REJECTED records an explicit denial with a reason.
enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum TagAssignmentSource {
  AUTOMATIC
  MANUAL
}

enum InitialPaymentType {
  FULL_PAYMENT
  DOWN_PAYMENT
  RESERVATION
}

enum LearnWorldsAccessType {
  COURSE
  BUNDLE
  SUBSCRIPTION
}

// A sellable thing (mentorship program, course, bundle, add-on). The catalog
// row is intentionally thin — pricing detail belongs on the enrollment so we
// can record discounts and historical price changes without versioning Product.
//
// Flags drive sales-flow behavior:
// - `isMainProduct` marks the flagship mentorship (only one expected; used to
//   surface defaults in the UI and reports).
// - `allowsInstallments` lets the operator break the sale into a payment plan.
// - `requiresInitialPayment` forces the first installment to be flagged on
//   creation (down payment / reservation).
// - `generatesCommission` is the catalog-level switch for the referral
//   commission engine; `defaultCommissionPercent` is what the enrollment
//   pre-fills when the operator opens the commission editor.
model Product {
  id                       String           @id @default(cuid())
  name                     String
  slug                     String           @unique
  description              String?
  basePriceUsd             Decimal          @db.Decimal(14, 2)
  currency                 String           @default("USD")
  saleLimit                ProductSaleLimit @default(ONE_PER_STUDENT)
  allowsInstallments       Boolean          @default(true)
  requiresInitialPayment   Boolean          @default(false)
  generatesCommission      Boolean          @default(false)
  defaultCommissionPercent Decimal          @default(0) @db.Decimal(6, 2)
  isMainProduct            Boolean          @default(false)
  isActive                 Boolean          @default(true)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  enrollments              StudentProductEnrollment[]
  learnWorldsAccessConfigs LearnWorldsAccessConfig[]

  @@index([isActive])
  @@index([isMainProduct])
}

// One row per (student, product) sale. Carries the agreed price + currency at
// the moment of sale so future price changes on Product don't rewrite history.
//
// Money fields:
// - `totalAmountUsd` is what the student agreed to pay (post-discount).
// - `initialPaymentUsd` is the down payment / reservation amount expected on
//   day one when `requiresInitialPayment` is set on the product.
// - `balanceUsd` is a cached outstanding-balance figure refreshed by payment
//   writes; tests source it through `calculateEnrollmentBalance` so the cache
//   has a single derivation point.
// - `commissionBaseUsd` + `commissionPercent` carry the per-enrollment
//   override of the product's defaults; the canonical base derivation lives
//   in `deriveDefaultCommissionBaseFromInitialPayment`.
// LearnWorlds provisioning state:
// - `accessStatus` mirrors the LW account state for this enrollment.
// - `learnWorldsSyncStatus` is the last sync transition ("pending"|"ok"|
//   "error"); `learnWorldsSyncError` holds the human-readable failure if any.
model StudentProductEnrollment {
  id                     String           @id @default(cuid())
  studentId              String
  student                Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  productId              String
  product                Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  status                 EnrollmentStatus @default(ACTIVE)
  startedAt              DateTime?        @db.Date
  endsAt                 DateTime?        @db.Date
  totalAmountUsd         Decimal          @db.Decimal(14, 2)
  initialPaymentUsd      Decimal?         @db.Decimal(14, 2)
  balanceUsd             Decimal?         @db.Decimal(14, 2)
  installmentCount       Int?
  commissionBaseUsd      Decimal?         @db.Decimal(14, 2)
  commissionPercent      Decimal?         @db.Decimal(6, 2)
  currency               String           @default("USD")
  paymentAccountId       String?
  paymentAccount         PaymentAccount?  @relation(fields: [paymentAccountId], references: [id], onDelete: SetNull)
  accessStatus           AccessStatus     @default(PENDING)
  accessGrantedAt        DateTime?
  learnWorldsSyncStatus  String           @default("pending")
  learnWorldsSyncError   String?
  // Contract / approval state. Torre de Control owns the decision to grant
  // access: a new enrollment lands in PENDING_APPROVAL and access stays
  // PENDING until an operator approves the contract from Torre.
  contractStatus         ContractStatus   @default(PENDING_APPROVAL)
  contractUrl            String?
  // Test signing surface (Torre-internal). A secure token is minted when an
  // operator creates the test contract link; the public /contratos/firmar
  // page validates the token, never the login session. This can later be
  // swapped for a real GHL Documents integration without UI changes.
  contractSignatureToken          String?   @unique
  contractSignatureTokenCreatedAt DateTime?
  contractSignerName              String?
  contractSignedIp                String?
  contractSignedUserAgent         String?
  // Evidencia de firma electrónica del estudiante: versión de plantilla y
  // texto de aceptación congelados al firmar, más el hash SHA-256 del
  // contrato firmado (contenido + datos + firmante) para verificación.
  contractTemplateVersion         String?
  contractAcceptanceText          String?
  // Snapshot JSON de las cláusulas manuales vigentes al firmar (ManualClause[]),
  // para que el contrato congelado no cambie si Operaciones edita las cláusulas
  // configurables después de la firma.
  contractManualClausesSnapshot   String?   @db.Text
  contractStudentSignatureHash    String?
  // Imagen de la firma manuscrita del estudiante (data URL base64 PNG/JPEG)
  // capturada en la página pública de firma. Se ubica junto al nombre del
  // estudiante en el contrato web y en el PDF firmado.
  contractStudentSignatureImage   String?   @db.Text
  contractSignedAt       DateTime?
  // Firma del CEO (Jose David Naicipa Jiménez) registrada al aprobar desde
  // Torre. El hash CEO encadena el hash del estudiante con la identidad y la
  // fecha de aprobación.
  contractCeoSignerName  String?
  contractCeoSignedAt    DateTime?
  contractCeoSignedById  String?
  contractCeoSignedBy    User?            @relation("EnrollmentCeoSigner", fields: [contractCeoSignedById], references: [id], onDelete: SetNull)
  contractCeoSignatureHash String?
  // Imagen de la firma manuscrita de Jose Naicipa (data URL base64 PNG/JPEG)
  // cargada al aprobar desde Torre. Se ubica sobre LA EMPRESA en el PDF firmado.
  contractCeoSignatureImage String? @db.Text
  contractApprovedAt     DateTime?
  contractApprovedById   String?
  contractApprovedBy     User?            @relation("EnrollmentApprover", fields: [contractApprovedById], references: [id], onDelete: SetNull)
  contractRejectedAt     DateTime?
  contractRejectionReason String?
  notes                  String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  payments             Payment[]
  paymentSchedules     PaymentSchedule[]
  referralCommissions  EnrollmentReferralCommission[]

  @@index([studentId])
  @@index([productId])
  @@index([status])
  @@index([paymentAccountId])
  @@index([accessStatus])
  @@index([contractStatus])
  @@index([contractApprovedById])
  @@index([contractCeoSignedById])
}

// Where money actually lands (Stripe US, Hotmart BR, Wise EUR, etc.). Keeping
// the account separate from currency lets us track multi-currency processors.
//
// `ownerUserId` is the canonical link to the User who holds the account;
// `ownerName` mirrors the user's name at creation time as a denormalized
// label that survives user renames and stays useful when the owner row is
// nulled out. Same idea for `paymentProviderId`/`providerName`. The UI
// (Catálogo · Cuentas receptoras) only accepts the controlled FKs; the
// strings stay so legacy rows and reports keep rendering.
model PaymentAccount {
  id                String           @id @default(cuid())
  displayName       String           @unique
  ownerUserId       String?
  ownerUser         User?            @relation("PaymentAccountOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerName         String?
  paymentProviderId String?
  paymentProvider   PaymentProvider? @relation(fields: [paymentProviderId], references: [id], onDelete: SetNull)
  providerName      String?
  currency          String           @default("USD")
  isActive          Boolean          @default(true)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  payments    Payment[]
  enrollments StudentProductEnrollment[]

  @@index([isActive])
  @@index([ownerUserId])
  @@index([paymentProviderId])
}

// Controlled catalog of payment processors / banks / wallets (Davivienda,
// Nequi, Bancolombia, Stripe, Wise, Hotmart, …). Replaces the free-text
// `providerName` on PaymentAccount with a picker-friendly catalog the
// Catálogo tab manages. `type` is a free-form coarse classification (BANK /
// WALLET / PROCESSOR / OTHER) that we keep as string for forward-compat.
model PaymentProvider {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   @default("OTHER")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts PaymentAccount[]

  @@index([isActive])
}

// Tag catalog. Two independent flags drive lifecycle semantics:
// - `isAutomatic` marks tags the system itself owns: they cannot be deleted
//   by users and the reconciliation job is allowed to detach them.
// - `allowAutomaticAssignment` permits the reconciliation job to *attach* the
//   tag to matching students. The pair lets us seed a manual-curated tag and
//   later promote it to auto-attached without losing existing manual rows.
// `isActive` removes the tag from pickers without deleting historical data.
// The canonical automatic-tag name list lives in
// src/lib/operaciones-products.ts (getAutomaticTagNames).
model StudentTag {
  id                       String   @id @default(cuid())
  name                     String   @unique
  slug                     String   @unique
  description              String?
  color                    String?
  isAutomatic              Boolean  @default(false)
  allowAutomaticAssignment Boolean  @default(false)
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  assignments StudentTagAssignment[]

  @@index([isActive])
  @@index([allowAutomaticAssignment])
}

model StudentTagAssignment {
  id           String              @id @default(cuid())
  studentId    String
  student      Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tagId        String
  tag          StudentTag          @relation(fields: [tagId], references: [id], onDelete: Cascade)
  source       TagAssignmentSource @default(MANUAL)
  assignedById String?
  createdAt    DateTime            @default(now())

  @@unique([studentId, tagId])
  @@index([studentId])
  @@index([tagId])
  @@index([source])
}

// A student-to-student referral. Multiple referrals can target the same
// referred student (e.g. influencer + community lead splitting credit). Splits
// are recorded per enrollment to allow varying commissions across products.
model Referral {
  id                 String   @id @default(cuid())
  referrerStudentId  String
  referrerStudent    Student  @relation("ReferralReferrer", fields: [referrerStudentId], references: [id], onDelete: Cascade)
  referredStudentId  String
  referredStudent    Student  @relation("ReferralReferred", fields: [referredStudentId], references: [id], onDelete: Cascade)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  commissions EnrollmentReferralCommission[]

  @@unique([referrerStudentId, referredStudentId])
  @@index([referrerStudentId])
  @@index([referredStudentId])
}

// Split of a single enrollment's commissionable base across referrals. The
// percentages on a given enrollment must sum to 100; see
// validateReferralSplitsSumTo100 in src/lib/operaciones-products.ts.
model EnrollmentReferralCommission {
  id                  String   @id @default(cuid())
  enrollmentId        String
  enrollment          StudentProductEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  referralId          String
  referral            Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  splitPercent        Decimal  @db.Decimal(6, 2)
  commissionBaseUsd   Decimal  @db.Decimal(14, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([enrollmentId, referralId])
  @@index([enrollmentId])
  @@index([referralId])
}

// LearnWorlds access tied to a product. A product may grant access to several
// LW courses/bundles, hence the 1-to-many.
//
// - `lwProductType` is the kind of LW resource (course/bundle/subscription).
// - `lwExternalId` is the LW slug or id pulled from the LW admin API (see
//   CLAUDE.md for endpoint quirks); paired with productId it is unique.
// - `lwDisplayName` is the human label cached from LW for UI listings so we
//   don't roundtrip to LW on every render.
model LearnWorldsAccessConfig {
  id            String                @id @default(cuid())
  productId     String
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  lwProductType LearnWorldsAccessType
  lwExternalId  String
  lwDisplayName String?
  description   String?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([productId, lwExternalId])
  @@index([productId])
  @@index([lwProductType])
  @@index([isActive])
}

// ─── Comunidad Dropi ─────────────────────────────────────────────────────────
// Independent surface for the Dropi sellers community. Lives next to the
// Operaciones / Estudiantes 1-1 spine, never on top of it: a community member
// can optionally be linked to a Student (`linkedStudentId`) when they are also
// a 1-1 mentee, but Student remains the source of truth for mentorship and is
// never required to have a community-member row.

// Lifecycle of a community member. Drives the dashboard "operational" filter
// without touching `currentSegment` (segment is analytical, status is human).
enum DropiMemberStatus {
  ACTIVE
  INACTIVE
  WATCHLIST
}

// Reason a follow-up was opened. Mirrors the segments that drive the
// auto-generated cases plus an explicit "OTHER" for manual ones.
enum DropiFollowUpReason {
  ZERO_SALES
  DROP
  HIGH_RETURN
  LOW_VOLUME
  TOP_PERFORMER
  OTHER
}

enum DropiFollowUpStatus {
  OPEN
  IN_PROGRESS
  DONE
  DISMISSED
}

// Structured outcome of the most recent contact round (Phase B). Stays
// independent from the free-form `result` field on DropiFollowUp so reporting
// can group by outcome without parsing prose.
enum DropiFollowUpOutcome {
  ANSWERED
  NO_ANSWER
  INTERESTED
  NOT_INTERESTED
  SCHEDULED
  NO_REPLY
  OTHER
}

// Channel the operator used to reach the member.
enum DropiContactChannel {
  WHATSAPP
  CALL
  EMAIL
  OTHER
}

enum DropiPriority {
  P1
  P2
  P3
  P4
}

// One row per Dropi community member. Identity is fuzzy (email, phone, Dropi
// id), so we keep them all nullable and rely on the import upsert logic in
// src/lib/comunidad-dropi-import.ts to resolve duplicates. `currentSegment`
// and `currentPriority` are denormalized caches refreshed by the segmentation
// engine after every confirmed import.
model DropiCommunityMember {
  id               String             @id @default(cuid())
  fullName         String?
  email            String?
  phone            String?
  country          String?
  dropiExternalId  String?
  ghlContactId     String?
  currentSegment   String?
  currentPriority  DropiPriority?
  currentStatus    DropiMemberStatus  @default(ACTIVE)
  firstReportedAt  DateTime?
  lastReportedAt   DateTime?
  notes            String?
  linkedStudentId  String?
  linkedStudent    Student?           @relation(fields: [linkedStudentId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  weeklyMetrics    DropiWeeklyMetric[]
  monthlyMetrics   DropiMonthlyMetric[]
  followUps        DropiFollowUp[]
  studentLinkAudit DropiStudentLinkAudit[]

  @@index([email])
  @@index([phone])
  @@index([country])
  @@index([linkedStudentId])
  @@index([currentSegment])
  @@index([currentPriority])
  @@index([currentStatus])
}

model DropiWeeklyMetric {
  id                    String               @id @default(cuid())
  memberId              String
  member                DropiCommunityMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  periodStart           DateTime             @db.Date
  periodEnd             DateTime             @db.Date
  ordersEntered         Int                  @default(0)
  ordersMoved           Int                  @default(0)
  ordersDelivered       Int                  @default(0)
  ordersReturned        Int                  @default(0)
  movementRate          Decimal              @default(0) @db.Decimal(8, 2)
  deliveryRate          Decimal              @default(0) @db.Decimal(8, 2)
  returnRate            Decimal              @default(0) @db.Decimal(8, 2)
  previousOrdersEntered Int?
  deltaOrdersEntered    Int?
  deltaOrdersPercent    Decimal?             @db.Decimal(8, 2)
  calculatedSegment     String?
  calculatedPriority    DropiPriority?
  country               String?
  importBatchId         String?
  importBatch           DropiImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  rawRow                Json?
  createdAt             DateTime             @default(now())

  @@unique([memberId, periodStart, periodEnd])
  @@index([memberId])
  @@index([periodStart, periodEnd])
  @@index([calculatedSegment])
  @@index([calculatedPriority])
  @@index([importBatchId])
}

model DropiMonthlyMetric {
  id                  String               @id @default(cuid())
  memberId            String
  member              DropiCommunityMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  year                Int
  month               Int
  ordersEntered       Int                  @default(0)
  ordersMoved         Int                  @default(0)
  ordersDelivered     Int                  @default(0)
  ordersReturned      Int                  @default(0)
  monthOverMonthDelta Decimal?             @db.Decimal(8, 2)
  trend               String?
  calculatedSegment   String?
  calculatedPriority  DropiPriority?
  country             String?
  importBatchId       String?
  importBatch         DropiImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  rawRow              Json?
  createdAt           DateTime             @default(now())

  @@unique([memberId, year, month])
  @@index([memberId])
  @@index([year, month])
  @@index([trend])
  @@index([importBatchId])
}

model DropiImportBatch {
  id             String       @id @default(cuid())
  fileName       String
  fileHash       String?
  reportType     String
  periodStart    DateTime?    @db.Date
  periodEnd      DateTime?    @db.Date
  year           Int?
  month          Int?
  country        String?
  rowsTotal      Int          @default(0)
  rowsProcessed  Int          @default(0)
  rowsFailed     Int          @default(0)
  status         ImportStatus @default(PENDING)
  errors         Json?
  uploadedById   String?
  uploadedBy     User?        @relation("DropiImportUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  weeklyMetrics  DropiWeeklyMetric[]
  monthlyMetrics DropiMonthlyMetric[]

  @@unique([fileHash])
  @@index([reportType])
  @@index([status])
  @@index([createdAt])
  @@index([uploadedById])
}

// Operational case opened on a community member after a segmentation pass.
// The system auto-generates follow-ups after every confirmed import; the team
// can also create them manually. `sourceWeeklyMetricId` / `sourceMonthlyMetricId`
// keep the trigger metric pinned so de-duplication can avoid re-opening the
// same case for the same period.
model DropiFollowUp {
  id                    String                @id @default(cuid())
  memberId              String
  member                DropiCommunityMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  reason                DropiFollowUpReason
  priority              DropiPriority         @default(P3)
  status                DropiFollowUpStatus   @default(OPEN)
  assignedToId          String?
  assignedTo            User?                 @relation("DropiFollowUpAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  suggestedAction       String?
  notes                 String?
  result                String?
  // Phase B: structured outcome + channel of the last contact round, plus a
  // snooze used to defer a case without losing its dueDate. The free-form
  // `result` and `notes` fields stay alongside so operators can keep context
  // that does not fit into the picker.
  outcome               DropiFollowUpOutcome?
  contactChannel        DropiContactChannel?
  snoozedUntil          DateTime?
  sourceWeeklyMetricId  String?
  sourceMonthlyMetricId String?
  dueDate               DateTime?
  contactedAt           DateTime?
  nextActionAt          DateTime?
  createdById           String?
  createdBy             User?                 @relation("DropiFollowUpCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([memberId])
  @@index([reason])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([dueDate])
  @@index([outcome])
  @@index([contactChannel])
  @@index([snoozedUntil])
}

// Audit log of link/unlink actions between a Dropi member and a 1-1 Student.
// Optional but recommended by the blueprint so reviewers can trace why a
// link exists or was broken. memberId and studentId are nullable + SetNull
// so the audit row survives deletion of either side and history stays intact.
model DropiStudentLinkAudit {
  id            String                @id @default(cuid())
  memberId      String?
  member        DropiCommunityMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  studentId     String?
  student       Student?              @relation("DropiLinkAuditStudent", fields: [studentId], references: [id], onDelete: SetNull)
  action        String
  reason        String?
  createdById   String?
  createdBy     User?                 @relation("DropiLinkAuditActor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now())

  @@index([memberId])
  @@index([studentId])
  @@index([createdAt])
}
